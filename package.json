{
  "name": "aloha-app",
  "version": "2.21.14",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "author": {
    "name": "Aloha"
  },
  "scripts": {
    "turbo": "turbo",
    "build": "cross-env NODE_ENV=production react-router build",
    "build:all": "turbo build --cache-dir=.turbo",
    "clean": "git clean -xdf node_modules dist",
    "clean:workspaces": "turbo clean",
    "dev": "react-router dev",
    "dev:all": "cross-env FORCE_COLOR=1 turbo dev --parallel",
    "start": "cross-env NODE_ENV=production react-router-serve ./build/server/index.js",
    "start:with-env": "pnpm with-env pnpm start",
    "with-env": "dotenv -e ./.env --",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "lint:all": "turbo lint --cache-dir=.turbo --continue -- --cache --cache-location \"node_modules/.cache/.eslintcache\"",
    "lint:fix:all": "turbo lint --cache-dir=.turbo --continue -- --fix --cache --cache-location \"node_modules/.cache/.eslintcache\"",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "format:fix": "turbo format --cache-dir=.turbo --continue -- --write --cache --cache-location=\"node_modules/.cache/.prettiercache\" --ignore-path=\"../../.gitignore\"",
    "typecheck": "react-router typegen && tsc",
    "typecheck:all": "turbo typecheck --cache-dir=.turbo",
    "test": "turbo test --cache-dir=.turbo",
    "test:unit": "vitest run",
    "update": "pnpm update -r",
    "syncpack:list": "pnpm dlx syncpack list-mismatches",
    "syncpack:fix": "pnpm dlx syncpack fix-mismatches",
    "react-router:typegen": "react-router typegen",
    "supabase": "supabase",
    "supabase:start": "supabase status || supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status": "supabase status",
    "supabase:test": "supabase db test",
    "supabase:db:lint": "supabase db lint",
    "supabase:deploy": "supabase link --project-ref $SUPABASE_PROJECT_REF && supabase db push",
    "supabase:typegen": "supabase gen types typescript --local > ./app/lib/database.types.ts",
    "supabase:db:dump:local": "supabase db dump --local --data-only",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --cache-location ./node_modules/.cache/eslint --fix",
      "prettier --write --cache --cache-location=node_modules/.cache/.prettiercache"
    ],
    "*.{json,md,css}": [
      "prettier --write --cache --cache-location=node_modules/.cache/.prettiercache"
    ]
  },
  "prettier": "@aloha/prettier-config",
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "overrides": {
      "react-is": "19.0.0",
      "zod": "3.25.76"
    },
    "ignoredBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/react": "^3.0.143",
    "@aloha/eslint-config": "workspace:*",
    "@aloha/prettier-config": "workspace:*",
    "@aloha/tailwind-config": "workspace:*",
    "@aloha/tsconfig": "workspace:*",
    "@aloha/ui": "workspace:*",
    "@edge-csrf/core": "2.5.3-cloudflare-rc1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.141",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "i18next-resources-to-backend": "^1.2.1",
    "isbot": "^5.1.32",
    "lint-staged": "^16.4.0",
    "lucide-react": "^0.562.0",
    "next-themes": "0.4.6",
    "pino": "^10.1.0",
    "prettier": "^3.7.4",
    "react": "catalog:",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.69.0",
    "react-i18next": "^16.5.0",
    "react-router": "^7.12.0",
    "sonner": "^2.0.7",
    "supabase": "catalog:",
    "tailwindcss": "4.1.18",
    "turbo": "^2.6.2",
    "tw-animate-css": "catalog:",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.1.3",
    "zod": "catalog:"
  },
  "dependencies": {
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "5.2.8",
    "ag-grid-community": "^35.2.1",
    "ag-grid-react": "^35.2.1"
  }
}
