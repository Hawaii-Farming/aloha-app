{
  "name": "web",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_ENV=production react-router build",
    "dev": "react-router dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "start": "cross-env NODE_ENV=production react-router-serve ./build/server/index.js",
    "start:with-env": "pnpm with-env pnpm start",
    "with-env": "dotenv -e ./.env --",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "react-router:typegen": "react-router typegen",
    "supabase": "supabase",
    "supabase:start": "supabase status || supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:status": "supabase status",
    "supabase:test": "supabase db test",
    "supabase:db:lint": "supabase db lint",
    "supabase:deploy": "supabase link --project-ref $SUPABASE_PROJECT_REF && supabase db push",
    "supabase:typegen": "pnpm run supabase:typegen:packages && pnpm run supabase:typegen:app",
    "supabase:typegen:packages": "supabase gen types typescript --local > ../../packages/supabase/src/database.types.ts",
    "supabase:typegen:app": "supabase gen types typescript --local > ./lib/database.types.ts",
    "supabase:db:dump:local": "supabase db dump --local --data-only"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/react": "^3.0.143",
    "@aloha/ai": "workspace:*",
    "@aloha/auth": "workspace:*",
    "@aloha/database-webhooks": "workspace:*",
    "@aloha/shared": "workspace:*",
    "@aloha/supabase": "workspace:*",
    "@aloha/ui": "workspace:*",
    "@edge-csrf/core": "2.5.3-cloudflare-rc1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-router/fs-routes": "7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@supabase/supabase-js": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.141",
    "date-fns": "^4.1.0",
    "i18next-resources-to-backend": "^1.2.1",
    "isbot": "^5.1.32",
    "lucide-react": "^0.562.0",
    "next-themes": "0.4.6",
    "react": "catalog:",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.69.0",
    "react-i18next": "^16.5.0",
    "react-router": "^7.12.0",
    "tw-animate-css": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@aloha/eslint-config": "workspace:*",
    "@aloha/prettier-config": "workspace:*",
    "@aloha/tailwind-config": "workspace:*",
    "@aloha/tsconfig": "workspace:*",
    "@react-router/dev": "^7.12.0",
    "@types/react": "catalog:",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "supabase": "catalog:",
    "tailwindcss": "4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
