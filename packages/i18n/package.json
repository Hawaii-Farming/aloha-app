{
  "name": "@aloha/i18n",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@aloha/prettier-config",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/i18n-server.ts",
    "./client": "./src/i18n-client.ts",
    "./provider": "./src/i18n-provider.tsx"
  },
  "devDependencies": {
    "@aloha/eslint-config": "workspace:*",
    "@aloha/prettier-config": "workspace:*",
    "@aloha/shared": "workspace:*",
    "@aloha/tailwind-config": "workspace:*",
    "@aloha/tsconfig": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "react-i18next": "^16.5.0"
  },
  "dependencies": {
    "i18next": "^25.7.3",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-resources-to-backend": "^1.2.1"
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
